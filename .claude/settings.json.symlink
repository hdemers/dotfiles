{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_MAX_TIMEOUT_MS": "300000",
    "ENABLE_SEARCH_TOOL": "auto:1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Edit(/home/hdemers/Dropbox/Agents/**)",
      "Edit(/home/hdemers/.cache/jira/**)",
      "Edit(/home/hdemers/.distrobox/homes/grubhub-dev/.cache/jira/**)",
      "Edit(/tmp/**)",
      "Edit(/home/hdemers/.cache/uv/**)",
      "Edit(/home/hdemers/.distrobox/homes/grubhub-dev/.cache/uv/**)",
      "WebFetch(domain:dev-jenkins.gdp.data.grubhub.com)",
      "WebFetch(domain:dev-azkaban-dr.gdp.data.grubhub.com)",
      "Bash(jira:*)"
    ],
    "deny": [
      "Edit(/.jj/**)"
    ]
  },
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "gdp@gdp-cli-marketplace": true,
    "on-call@gdp-cli-marketplace": false,
    "coding@gdp-cli-marketplace": false,
    "pyright-lsp@claude-plugins-official": true,
    "misc@gdp-cli-marketplace": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "jira:*",
      "projects:*",
      "schedule:*",
      "flowlogs:*",
      "listemr:*",
      "trino:*",
      "pr-discussions:*",
      "jenkins:*",
      "notify:*"
    ]
  },
  "effortLevel": "medium",
  "voiceEnabled": false,
  "skipDangerousModePermissionPrompt": true
}
