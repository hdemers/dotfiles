{
  "selectedAuthType": "gemini-api-key",
  "theme": "Atom One",
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "vimMode": false,
    "previewFeatures": true,
    "preferredEditor": "neovim",
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    },
    "enableNotifications": true,
    "plan": {
      "directory": "",
      "enabled": true
    }
  },
  "tools": {
    "shell": {
      "showColor": true,
      "enableInteractiveShell": false
    }
  },
  "experimental": {
    "enableAgents": true,
    "modelSteering": true
  },
  "ui": {
    "theme": "ANSI",
    "showLineNumbers": false,
    "useBackgroundColor": true,
    "inlineThinkingMode": "off",
    "footer": {
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota"
      ]
    }
  },
  "model": {
    "name": "gemini-3.1-pro-preview"
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "AGENTS.local.md"
    ]
  },
  "agents": {
    "overrides": {
      "generalist": {
        "runConfig": {
          "maxTimeMinutes": 60,
          "maxTurns": -1
        },
        "enabled": true
      }
    }
  }
}